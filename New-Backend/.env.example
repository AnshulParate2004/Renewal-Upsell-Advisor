# PostgreSQL — if password has # % @ etc., URL-encode in the URL (# → %23) and use quotes:
# DATABASE_URL="postgresql+asyncpg://postgres:my%23pass@host:5432/postgres?ssl=require"
DATABASE_URL=postgresql+asyncpg://rnu:rnu_dev@localhost:5433/revenue_navigator
DATABASE_URL_SYNC=postgresql+psycopg2://rnu:rnu_dev@localhost:5433/revenue_navigator

# MongoDB / Redis / Celery
MONGODB_URL=mongodb://localhost:27018/revenue_navigator
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# Auth
JWT_SECRET=dev-secret-change-in-production

# Scoring mode: formula | ml
SCORING_MODE=formula

# --- LLM credentials (referenced by app_settings.config.llm_routing JSON) ---
# Per-task models are configured in DB via GET/PATCH /api/v1/settings/llm-config
# using schemas/llm_config.example.json. Env vars below are credential sources only.

# Azure OpenAI (ChatLiteLLM)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# OpenAI direct (optional)
OPENAI_API_KEY=

# Anthropic (optional — for email_intent task in llm_config.example.json)
ANTHROPIC_API_KEY=

# Env fallbacks when no tenant llm_routing in DB (optional per-task overrides)
LITELLM_MODEL=gpt-4o-mini
LITELLM_SENTIMENT_MODEL=
LITELLM_INTENT_MODEL=
LITELLM_PERSONALIZATION_MODEL=
LITELLM_SUMMARY_MODEL=

# Azure Speech (voice STT/TTS)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=centralindia

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
